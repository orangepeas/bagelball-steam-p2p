[layer_names]

3d_physics/layer_1="everything"
3d_physics/layer_2="ball"
3d_physics/layer_8="player"

[physics]

3d/physics_engine="GodotPhysics3D"
3d/default_gravity=40.0
jolt_3d/sleep/enabled=false
jolt_3d/limits/max_linear_velocity=3000.0

[rendering]

rendering_device/d3d12/max_resource_descriptors_per_frame=49152
rendering_device/d3d12/max_sampler_descriptors_per_frame=2048
rendering_device/d3d12/max_misc_descriptors_per_frame=1536
textures/vram_compression/import_etc2_astc=true
